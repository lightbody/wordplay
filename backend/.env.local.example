# Copy this to .env.local and fill in your WorkOS values.

# WorkOS — Development environment Client ID, for local dev only
WORKOS_JWKS_URL=https://api.workos.com/sso/jwks/client_YOUR_DEVELOPMENT_CLIENT_ID

# Web Push — your own local VAPID keypair, so push notifications work in dev
# too (localhost is a secure context, no HTTPS tunnel needed). Generate once
# with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@localhost
